{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(npx jest *)",
      "Bash(npx vitest *)",
      "Bash(git checkout *)",
      "Bash(npm --version)",
      "WebFetch(domain:pypi.org)",
      "Bash(ps -p 90129 -o comm=)",
      "Bash(PORT=3001 node dist/index.js)",
      "Bash(PORT=8080 node *)",
      "Bash(npm run *)",
      "Bash(npx tsx *+)",
      "Bash(curl -s http://localhost:3000/api/assets?page=1+)",
      "Bash(curl -X POST http://localhost:3000/api/auth/login -H \"Content-Type: application/json\" -d \"{\\\\\"email\\\\\":\\\\\"admin@test.com\\\\\",\\\\\"password\\\\\":\\\\\"admin123\\\\\"}\")",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\([{ 'id':u['id'],'email':u['email'],'role':u['role']}\\) for u in d.get\\('users',[]\\)]\")",
      "Bash(python -c ' *)",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\(d.get\\('compilerOptions',{}\\).get\\('paths',{}\\)\\)\")",
      "Bash(pkill -f \"vite\")",
      "Bash(npx tsc *)",
      "Bash(node -e \"const p = require\\('./node_modules/@tanstack/react-query/package.json'\\); console.log\\(p.version\\);\")",
      "Bash(git add *)",
      "Bash(node -e ' *)",
      "Bash(node -e \"const db = require\\('./dist/config/database'\\).db; console.log\\('maintenance_schedules', typeof db.maintenance_schedules, db.maintenance_schedules?.length\\);\")",
      "Bash(node -e \"const db_orig = { a:1, b:2 }; const loaded = { a:10 }; const result = { ...db_orig, ...loaded }; console.log\\(result\\);\")",
      "Bash(node -e \"const db = require\\('./dist/config/database'\\).default; console.log\\('maintenance_schedules type:', typeof db.maintenance_schedules, 'tables:', Object.keys\\(db\\).join\\(', '\\)\\);\")",
      "Bash(echo \"Backend starting, PID: $!\")",
      "Bash(curl -s http://localhost:3000/health)",
      "Bash(curl -s http://localhost:3000/api/assets)",
      "Bash(curl -s http://localhost:3000/api/auth/login -H \"Content-Type: application/json\" -d \"{\\\\\"username\\\\\":\\\\\"admin\\\\\",\\\\\"password\\\\\":\\\\\"admin123\\\\\"}\")",
      "Bash(taskkill /f /im node.exe)",
      "Bash(curl -s http://localhost:3000/api/health)",
      "Bash(curl -s http://localhost:3000/api/assets/inventory-report -H \"Authorization: Bearer test\")",
      "Bash(curl *)",
      "Bash(netstat -ano)",
      "Bash(taskkill *)",
      "Bash(awk '{print $5}')",
      "Bash(git commit -m ' *)",
      "Bash(git push *)"
    ]
